{
  "version": 2,
  "buildCommand": "echo 'No build required for static HTML'",
  "outputDirectory": ".",
  "public": true,
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/deepseek_html_20260616_7fc154 (1).html"
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ]
}
